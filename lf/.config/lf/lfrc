### Custom Commands ###

# Go to media dir
cmd media ${{
  lf -remote "send $id cd '/run/media/$USER/'"
}}
map gM media

### FILE CREATION ###
cmd mk ${{
  printf "Name: "
  read -r name
  [ -z "$name" ] && exit

  printf "Type (dir/file/script/proj): "
  read -r type
  case "$type" in
    dir) mkdir -pv -- "$name" ;;
    file) :> "$name" ;;
    script) mkscript -n "$name" && lf -remote "send $id cd '~/Scripts/'" ;;
    proj) projtool mkproj -n "$name" && lf -remote "send $id cd '~/Projects/$name'" ;;
    *) echo "Unknown type." ;;
  esac
  lf -remote 'send reload'
}}
map mm mk

### DELETE / TRASH ###
cmd trash %{{
    for f in $fx; do
				echo "trash|$f" >> /tmp/lf_undo_$USER
        trash-put -vr "$f"
    done
}}
cmd trash-list ${{
    trash-list | moar
}}
cmd trash-restore ${{
    trash-restore
}}
cmd trash-empty %{{
    trash-empty
}}
cmd remove %{{
    for f in $fx; do
        rm -rfv "$f"
    done
}}
map DD remove
map dd trash
map tt trash-list
map tr trash-restore
map te trash-empty

### TOGGLE EXECUTABLE / PERMISSIONS ###
cmd chmod %{{
  oldperms=$(stat -c "%a" "$f")
  printf "Chmod bits: "
  read -r bits
  [ -z "$bits" ] && exit
  chmod "$bits" "$f"
  echo "chmod|$oldperms|$f" >> /tmp/lf_undo_$USER
  lf -remote 'send reload'
}}
map et chmod

### ARCHIVE / EXTRACT ###
cmd extract %{{
  for f in $fx; do
    archives extract "$f"
  done
  lf -remote 'send reload'
}}
map ex extract

cmd archive %{{
  printf " Archive name (.tar.gz/.zip/.rar): "
  read -r out
  [ -z "$out" ] && exit
  archives archive "$out" $fx
  lf -remote 'send reload'
}}
map er archive

### FZF JUMP ###
cmd fzf_jump ${{
  res=$(fd --hidden --exclude .git . 2>/dev/null | \
    fzf --reverse \
        --preview '[ -d {} ] && eza -a --tree --level=2 --group-directories-first --color=always --icons {} 2>/dev/null || batcat --color=always --style=numbers --line-range=:100 {} 2>/dev/null || cat {}' \
        </dev/tty)
  [ -z "$res" ] && exit
  if [ -d "$res" ]; then
    lf -remote "send $id cd '$res'"
  else
    lf -remote "send $id cd '$(dirname "$res")'"
    lf -remote "send $id select '$res'"
    lf -remote "send $id open"
  fi
}}
map fj fzf_jump

### FOLLOW SYMLINK ###
cmd follow-link ${{
  [ ! -L "$f" ] && echo "Not a symlink." && exit
  target=$(readlink -f "$f")
  if [ -d "$target" ]; then
    lf -remote "send $id cd '$target'"
  elif [ -f "$target" ]; then
    lf -remote "send $id cd '$(dirname "$target")'"
    ${EDITOR:-nvim} "$target"
  fi
}}
map gf follow-link

### RENAME ###
cmd rename ${{
  old="$f"
  oldname=$(basename "$old")
  printf "New name: "
  read -r newname
  [ -z "$newname" ] && exit
  newpath="$(dirname "$old")/$newname"
  mv -- "$old" "$newpath"
  echo "rename|$old|$newpath" >> /tmp/lf_undo_$USER
  lf -remote 'send reload'
}}
map r rename

### OPEN FILE ###
cmd open ${{
  mime=$(file --mime-type -Lb "$f")
  ext="${f##*.}"

  case "$mime" in
    text/*|application/json|application/xml)
      ${EDITOR:-nvim} "$f" ;;
    image/*)
      sxiv "$f" 2>/dev/null || imv "$f" 2>/dev/null || chafa "$f" ;;
    video/*|audio/*)
      mpv "$f" ;;
    application/pdf)
      zathura "$f" 2>/dev/null || pdftotext "$f" - | less ;;
    *)
      # fallback based on extension
      case "$ext" in
        sh|py|c|cpp|lua|rs|go|js|ts|md|json|yml|yaml)
          ${EDITOR:-nvim} "$f" ;;
        jpg|jpeg|png|gif|bmp|webp|svg)
          sxiv "$f" 2>/dev/null || imv "$f" ;;
        mp4|mkv|mp3|flac|ogg|wav)
          mpv "$f" ;;
        pdf)
          zathura "$f" 2>/dev/null || pdftotext "$f" - | less ;;
        *) xdg-open "$f" >/dev/null 2>&1 ;;
      esac
      ;;
  esac
}}
map <enter> open

