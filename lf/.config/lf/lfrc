### Secure Copy ###
cmd scp ${{
  read -rp "Port (default 22): " port
  port="${port:-22}"
  read -rp "Host (user@host:/path): " host
  [ -z "$host" ] && exit
  if [ -n "$fx" ]; then
    echo "$fx" | xargs -I{} scp -P "$port" "{}" "$host"
  else
    scp -P "$port" "$f" "$host"
  fi
}}
map cs scp

cmd undo ${{
  [ ! -f /tmp/lf_undo_$USER ] && echo "Nothing to undo." && exit
  last=$(tail -1 /tmp/lf_undo_$USER)
  action=$(echo "$last" | cut -d'|' -f1)
  data=$(echo "$last" | cut -d'|' -f2-)

  case "$action" in
    paste)
      rm -rf "$data"
      sed -i '$d' /tmp/lf_undo_$USER
      lf -remote 'send reload'
      ;;
    rename)
      old=$(echo "$data" | cut -d'|' -f1)
      new=$(echo "$data" | cut -d'|' -f2)
      mv -- "$new" "$old"
      sed -i '$d' /tmp/lf_undo_$USER
      lf -remote 'send reload'
      ;;
    chmod)
      perms=$(echo "$data" | cut -d'|' -f1)
      fp=$(echo "$data" | cut -d'|' -f2)
      chmod "$perms" "$fp"
      sed -i '$d' /tmp/lf_undo_$USER
      lf -remote 'send reload'
      ;;
		trash)
			path=$(echo "$data" | cut -d'|' -f2)
			filename=$(basename "$path")
			trashinfo=~/.local/share/Trash/info/${filename}.trashinfo
			trashed=~/.local/share/Trash/files/${filename}
			if [ -e "$trashed" ] && [ -f "$trashinfo" ]; then
				mv "$trashed" "$path"
				rm "$trashinfo"
				sed -i '$d' /tmp/lf_undo_$USER
			else
				echo "Can't find $filename in trash"
			fi
			lf -remote 'send reload'
			;;
  esac
}}
map u undo
